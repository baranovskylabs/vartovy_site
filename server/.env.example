# --- Lemon Squeezy ----------------------------------------------------
# Ключ із https://app.lemonsqueezy.com/settings/api  (тип: API Key)
LEMONSQUEEZY_API_KEY=

# Секрет, який ти задаєш при створенні вебхука у Lemon Squeezy.
# Має збігатися з полем "Signing secret" у налаштуваннях вебхука.
LEMONSQUEEZY_WEBHOOK_SECRET=

# --- Supabase (заповнюються автоматично у середовищі Edge Functions) --
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Підпис офлайн-токенів -------------------------------------------
# Згенерувати: deno run --allow-write server/scripts/generate-signing-keys.ts
LICENSE_SIGNING_PRIVATE_KEY=

# --- Інше -------------------------------------------------------------
# Сіль для хешу IP в логах (просто рандомний рядок).
IP_HASH_SALT=change-me-to-random-string

# Кому дозволено CORS-запити (origin сайту). Можна кілька через кому.
ALLOWED_ORIGINS=https://vartovy.app,https://www.vartovy.app
